# Node deps / build output for bundled understand-anything plugin
.claude/plugins/**/node_modules/
.claude/plugins/**/dist/
.claude/plugins/**/.turbo/

# understand-anything generated artifacts
.understand-anything/

# Python caches from bundled skill scripts
**/__pycache__/
*.pyc

# pslab-sns app
/node_modules/
/dist/
.env
*.tsbuildinfo

# 오토파일럿 클라이언트별 격리 저장소 (런타임 생성)
/data/
# 실제 클라이언트 설정표는 자격/내부 정보 포함 → 커밋 금지 (.example.json만 추적)
/clients/*.json
!/clients/*.example.json
